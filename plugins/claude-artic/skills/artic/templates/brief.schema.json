{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Artic Brief",
  "type": "object",
  "required": ["artic_version", "project", "style", "references", "implementation", "language", "copy_policy"],
  "properties": {
    "artic_version": {"type": "string"},
    "project": {
      "type": "object",
      "required": ["name", "type", "description", "target_users", "primary_goal"]
    },
    "style": {
      "type": "object",
      "required": ["desired_impression", "selected_preset", "likes", "dislikes", "fixed_assets", "search_facets"]
    },
    "references": {"type": "array"},
    "requirements": {"type": "object"},
    "constraints": {"type": "object"},
    "asset_policy": {"type": "object"},
    "risk_readiness": {
      "type": "object",
      "required": ["schema_version", "risk_categories", "quality_critical_requirements", "dynamic_required_fields", "missing_dynamic_required_fields", "readiness", "safe_assumptions", "unsafe_assumptions", "placeholder_boundary", "stop_conditions", "risk_summary", "completion_criteria"],
      "properties": {
        "schema_version": {"const": "artic-risk-readiness-v1"},
        "risk_categories": {"type": "array", "items": {"type": "string"}},
        "quality_critical_requirements": {"type": "array"},
        "dynamic_required_fields": {"type": "array", "items": {"type": "string"}},
        "missing_dynamic_required_fields": {"type": "array", "items": {"type": "string"}},
        "readiness": {
          "type": "object",
          "required": ["strategy", "preview", "implementation", "status"]
        },
        "safe_assumptions": {"type": "array", "items": {"type": "string"}},
        "unsafe_assumptions": {"type": "array", "items": {"type": "string"}},
        "placeholder_boundary": {"type": "string"},
        "stop_conditions": {"type": "array", "items": {"type": "string"}},
        "risk_summary": {"type": "string"},
        "completion_criteria": {"type": "array", "items": {"type": "string"}}
      }
    },
    "implementation": {"type": "object"},
    "language": {
      "type": "object",
      "required": ["locale", "output_language", "tone", "preserve_terms", "bilingual_terms"],
      "properties": {
        "locale": {"type": "string"},
        "output_language": {"type": "string"},
        "tone": {"type": "string"},
        "preserve_terms": {"type": "array", "items": {"type": "string"}},
        "bilingual_terms": {"type": "boolean"}
      }
    },
    "copy_policy": {"type": "string"}
  }
}
